# DashScope / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_PLANNER_MODEL=qwen3.6-plus
DASHSCOPE_VISION_MODEL=qwen3.6-plus
DASHSCOPE_CRITIC_MODEL=qwen3.6-plus
DASHSCOPE_REQUEST_MODEL=qwen3.6-plus
DASHSCOPE_TIMEOUT_SECONDS=300

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=PsAgent

# Aliyun image segmentation
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_CLOUD_REGION_ID=cn-shanghai
# ALIYUN_IMAGESEG_ENDPOINT=imageseg.cn-shanghai.aliyuncs.com
ALIYUN_SEGMENT_CONNECT_TIMEOUT_MS=10000
ALIYUN_SEGMENT_READ_TIMEOUT_MS=10000
ALIYUN_SEGMENT_MAX_ATTEMPTS=20
ALIYUN_SEGMENT_POLL_INTERVAL_SECONDS=1.0

# fal EVF-SAM segmentation
FAL_KEY=your_fal_api_key
FAL_EVF_SAM_MODEL=fal-ai/evf-sam
FAL_EVF_SAM_START_TIMEOUT_SECONDS=120
FAL_EVF_SAM_CLIENT_TIMEOUT_SECONDS=180
PSAGENT_SEGMENTATION_PROVIDER=auto
PSAGENT_SEGMENTATION_FALLBACK_PROVIDER=aliyun

# Upload validation
PSAGENT_MAX_UPLOAD_BYTES=15728640
PSAGENT_MAX_IMAGE_SIDE=8192
PSAGENT_MIN_IMAGE_SIDE=32
